# Appwrite Configuration
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_DATABASE_ID=your_database_id_here

# Collection IDs
APPWRITE_USERS_COLLECTION_ID=users
APPWRITE_SELLERS_COLLECTION_ID=sellers
APPWRITE_PRODUCTS_COLLECTION_ID=products
APPWRITE_ORDERS_COLLECTION_ID=orders
APPWRITE_CATEGORIES_COLLECTION_ID=categories

# Storage Bucket IDs
APPWRITE_PRODUCT_IMAGES_BUCKET_ID=product-images
APPWRITE_SELLER_DOCUMENTS_BUCKET_ID=seller-documents

# Razorpay Configuration (Sandbox)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
